# No Database Needed - Using JSON File Storage
# Just configure these settings

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRE=7d

# Admin Configuration
ADMIN_EMAIL=admin@uniglobal.com
ADMIN_PASSWORD=secure_password_here_change_immediately

# Server Configuration
PORT=5000
NODE_ENV=development

# WhatsApp Configuration (Optional)
WHATSAPP_API_KEY=your_twilio_api_key_here
WHATSAPP_ACCOUNT_SID=your_twilio_account_sid_here
WHATSAPP_PHONE_NUMBER=+1234567890
WHATSAPP_ADMIN_NUMBER=+1234567890

# CORS Configuration
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
